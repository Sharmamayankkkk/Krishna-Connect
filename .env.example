# -----------------------------------------------------------------------------
# Supabase Configuration
# Required for Authentication, Database, and Realtime features.
# You can find these updates in your Supabase Project Settings -> API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------

# Google Gemini API Key
# Used for AI-powered features (e.g., smart replies, content analysis).
# Get it from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Giphy API Key
# Used for the GIF picker in the chat input.
# Get it from: https://developers.giphy.com/dashboard/
NEXT_PUBLIC_GIPHY_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags & Monetization
# -----------------------------------------------------------------------------

# Enable/Disable monetization features (Ads, Premium tiers).
# Values: "true" or "false"
NEXT_PUBLIC_ENABLE_MONETIZATION=false

# Google AdSense Client ID
# Required if monetization is enabled.
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=