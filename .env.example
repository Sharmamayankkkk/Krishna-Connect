# =============================================================================
# Krishna Connect — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit your .env file — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# Get these from: Supabase Dashboard → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Google Gemini API Key
# Used for AI-powered features (smart replies, content analysis).
# Get it from: https://makersuite.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Giphy API Key
# Used for the GIF picker in chat.
# Get it from: https://developers.giphy.com/dashboard/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GIPHY_API_KEY=

# -----------------------------------------------------------------------------
# Monetization
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_MONETIZATION=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Web Push (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Maintenance Mode
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAINTENANCE_MODE=false
MAINTENANCE_BYPASS_SECRET=

# -----------------------------------------------------------------------------
# Stream SDK Keys (Video/Voice Calling)
# Get from: https://getstream.io/dashboard/
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_SECRET_KEY=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_PHONE_COLLECTION=false
