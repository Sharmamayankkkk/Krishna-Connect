# =============================================================================
# Krishna Connect Mobile — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your Supabase credentials.
#   cp .env.example .env
#
# These are the SAME Supabase credentials used by the web app.
# Find them at: Supabase Dashboard → Settings → API
#
# NEVER commit your .env file — it contains secrets.
# =============================================================================

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
